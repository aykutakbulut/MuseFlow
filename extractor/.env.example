# Bu dosyayı `.env` olarak kopyala ve doldur:  cp .env.example .env

# Caddy'nin HTTPS sertifikası alacağı alan adı.
# sslip.io kullan: VM'inin public IP'sini yaz, sonuna .sslip.io ekle.
# Örnek: VM IP'si 140.238.1.2 ise:
DOMAIN=140.238.1.2.sslip.io

# Basit erişim anahtarı (opsiyonel ama önerilir). Rastgele uzun bir string üret.
# Bu değer Vercel'de NEXT_PUBLIC_EXTRACTOR_TOKEN ile AYNI olmalı.
EXTRACTOR_TOKEN=
